# Global
ENVIRONMENT=development
LOG_LEVEL=INFO

# Network
API_HOST=0.0.0.0
API_PORT=8000

# Data stores and broker
DATABASE_URL=postgresql+asyncpg://risk:risk@postgres:5432/risk_monitor
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Security
JWT_SECRET=change-me-in-prod
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_KEY_ID=aegis-default-kid
JWT_ACCESS_TOKEN_MINUTES=60
AUTH_ACCESS_COOKIE_NAME=aegis_access_token
AUTH_REFRESH_COOKIE_NAME=aegis_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Models
MODEL_ACTIVATION_MIN_SAMPLES=64
MODEL_ACTIVATION_MIN_RELATIVE_IMPROVEMENT=0.02
MODEL_ACTIVATION_THRESHOLD_RATIO_MIN=0.5
MODEL_ACTIVATION_THRESHOLD_RATIO_MAX=2.0

# Integrations
SENTRY_DSN=
AUGUS_API_KEY=

# Services
ML_INFERENCE_URL=http://ml-inference:8000
FEATURE_ENRICHMENT_URL=http://feature-enrichment:8040
DATA_CONNECTOR_URL=http://data-connector:8030
API_GATEWAY_URL=http://api-gateway:8000
CORS_ALLOW_ORIGINS=http://app.localhost,http://localhost:5173,http://127.0.0.1:5173

# Messaging v2
RABBITMQ_EVENTS_V2_ROUTING_KEY=risk.events.v2.ingested
RABBITMQ_METRICS_ROUTING_KEY=risk.metrics.updated
RABBITMQ_REFERENCE_ROUTING_KEY=risk.reference.updated
REDIS_METRICS_CHANNEL=risk.metrics.live
RABBITMQ_QUEUE_TYPE=classic

# Data connector feeds
CONNECTORS_V2_ENABLED=true
CONNECTOR_HTTP_TIMEOUT_SECONDS=30
CONNECTOR_MAX_RETRIES=3
CONNECTOR_BACKOFF_MAX_SECONDS=1800
CONNECTOR_CIRCUIT_BREAKER_FAILURES=5
CONNECTOR_AUTO_INGEST_ON_REFERENCE_UPDATE=true
CONNECTOR_AUTO_INGEST_TENANT_ID=tenant-alpha
CONNECTOR_AUTO_INGEST_SUBJECT=connector-service
CONNECTOR_AUTO_INGEST_TIMEOUT_SECONDS=10
CONNECTOR_ENABLE_OFAC=true
CONNECTOR_ENABLE_FATF=true
CONNECTOR_ENABLE_ECB=true
CONNECTOR_ENABLE_MAXMIND=false
CONNECTOR_ENABLE_OPENSANCTIONS=false
CONNECTOR_ENABLE_IPINFO=false
CONNECTOR_ENABLE_BINLIST=false
CONNECTOR_ENABLE_HIBP=false
OFAC_SLS_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/SDN.CSV
OPENSANCTIONS_URL=https://api.opensanctions.org/match/default
OPENSANCTIONS_API_KEY=
FATF_SOURCE_URL=https://www.fatf-gafi.org/en/topics/high-risk-and-other-monitored-jurisdictions.html
IPINFO_BASE_URL=https://ipinfo.io
IPINFO_TOKEN=
BINLIST_BASE_URL=https://lookup.binlist.net
ECB_FX_URL=https://data-api.ecb.europa.eu/service/data
MAXMIND_DOWNLOAD_URL=
MAXMIND_LICENSE_KEY=
MAXMIND_ACCOUNT_ID=
HIBP_BASE_URL=https://haveibeenpwned.com/api/v3
HIBP_API_KEY=

# OAuth (Social Sign-In)
FRONTEND_BASE_URL=http://app.localhost
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://api.localhost/v1/auth/google/callback
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_REDIRECT_URI=http://api.localhost/v1/auth/apple/callback
