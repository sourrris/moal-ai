# moal-ai environment configuration

# Global
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
POSTGRES_DB=risk_monitor
POSTGRES_USER=risk
POSTGRES_PASSWORD=risk
DATABASE_URL=postgresql+asyncpg://risk:risk@postgres:5432/risk_monitor

# Security
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=60

# ML
ML_INFERENCE_URL=http://ml:8000
MODEL_DIR=/models

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
