# Vercel Environment Variables
# Set these in the Vercel Dashboard (Settings > Environment Variables).
# Do NOT commit actual values.

# ── Vercel Rewrite Target (runtime, NOT prefixed with VITE_) ──────────
# Backend API origin for Vercel rewrites — proxies /api/* to this host.
# No trailing slash.
BACKEND_API_ORIGIN=https://api.aegisai.com

# ── Build-time Variables (VITE_ prefix, baked into the JS bundle) ─────
# API base URL — set to /api so requests are proxied via Vercel rewrites.
VITE_API_BASE_URL=/api

# WebSocket notification service (direct connection, not proxied).
VITE_WS_BASE_URL=wss://ws.aegisai.com

# Control console links shown in the settings page.
VITE_CONTROL_TENANT_URL=https://control.aegisai.com
VITE_CONTROL_OPS_URL=https://ops.aegisai.com
